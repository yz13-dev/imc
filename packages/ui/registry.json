{
  "$schema": "https://ui.shadcn.com/schema/registry.json",
  "name": "yz13-imc-ui",
  "homepage": "https://ui.yz13.dev",
  "items": [
    {
      "name": "video",
      "type": "registry:block",
      "title": "Video",
      "description": "<video /> wrapper with muted autoplay, and in-view awareness",
      "registryDependencies": [
        "yz13-dev/imc/use-interval"
      ],
      "dependencies": [
        "motion",
        "zustand"
      ],
      "files": [
        {
          "path": "src/components/video.tsx",
          "target": "imc/video.tsx",
          "type": "registry:component"
        }
      ]
    },
    {
      "name": "use-interval",
      "type": "registry:hook",
      "title": "UseInterval",
      "description": "Simple implementation of interval hook",
      "files": [
        {
          "path": "src/hooks/use-interval.tsx",
          "target": "hooks/use-interval.tsx",
          "type": "registry:hook"
        }
      ]
    }
  ]
}
